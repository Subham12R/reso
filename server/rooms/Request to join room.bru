meta {
  name: Request to join room
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/rooms/join-requests
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "code": "{{roomCode}}",
    "displayName": "Alex"
  }
}

script:post-response {
  bru.setVar("requestId", res.body.requestId);
}

vars:pre-request {
